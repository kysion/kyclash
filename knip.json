{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["src/polyfills/*.js!", "src/types/networking-fixture.ts"],
  "project": ["src/**/*.{js,jsx,ts,tsx}!", "scripts/**/*.{js,mjs}!"],
  "include": [
    "files",
    "dependencies",
    "devDependencies",
    "unlisted",
    "unresolved",
    "binaries",
    "exports",
    "types",
    "duplicates",
    "cycles"
  ],
  "ignoreBinaries": ["rustc", "pkgbuild", "pkgutil", "xcrun"],
  "ignoreDependencies": ["lint-staged"],
  "ignoreIssues": {
    "src/types/generated/**": ["exports", "types"],
    "src/types/networking-fixture.ts": ["exports"],
    "src/types/networking.ts": ["exports", "types"],
    "src/types/proxy-view.ts": ["exports", "types"]
  },
  "cycles": {
    "dynamicImports": true
  }
}
