{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/kysion/kyclash/network-sidecar/schemas/kyclash-linux-peer-v1.schema.json",
  "title": "KyClash Linux production peer configuration v1",
  "description": "Public, secret-free configuration. Private TLS and WireGuard keys are accepted only from fixed systemd credentials. Duplicate JSON keys plus canonical CIDR, overlap, address-family, endpoint-host, and key checks are additionally rejected by the Go decoder.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "peer_id",
    "deployment_id",
    "tls",
    "wireguard",
    "listeners",
    "forwarding",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "peer_id": {
      "$ref": "#/$defs/identifier"
    },
    "deployment_id": {
      "$ref": "#/$defs/identifier"
    },
    "tls": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trust_mode",
        "minimum_version",
        "server_name",
        "local_certificate_sha256",
        "client_authentication"
      ],
      "properties": {
        "trust_mode": {
          "const": "system_roots",
          "description": "KyClash clients validate this Peer with their operating-system trust roots and the configured server_name."
        },
        "minimum_version": {
          "const": "1.3"
        },
        "server_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 253
        },
        "local_certificate_sha256": {
          "$ref": "#/$defs/sha256",
          "description": "Peer-local startup self-check of the leaf certificate DER. This is not a client certificate pin and does not replace system-root plus hostname validation."
        },
        "client_authentication": {
          "const": "wireguard_public_key"
        }
      }
    },
    "wireguard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "server_public_key_base64",
        "server_addresses",
        "clients",
        "mtu"
      ],
      "properties": {
        "server_public_key_base64": {
          "$ref": "#/$defs/wireguard_public_key"
        },
        "server_addresses": {
          "$ref": "#/$defs/host_prefixes"
        },
        "clients": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "items": {
            "$ref": "#/$defs/client"
          },
          "description": "Bounded WireGuard authorization list. Version 1 still permits only one active client and one active carrier; this is not a multi-tenant service claim."
        },
        "mtu": {
          "const": 1420
        }
      }
    },
    "listeners": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "prefixItems": [
        {
          "$ref": "#/$defs/quic_listener"
        },
        {
          "$ref": "#/$defs/wss_listener"
        },
        {
          "$ref": "#/$defs/tcp_listener"
        }
      ],
      "items": false
    },
    "forwarding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "tunnel_interface",
        "site_interface",
        "private_cidrs",
        "return_path"
      ],
      "properties": {
        "mode": {
          "const": "preprovisioned_linux_tun"
        },
        "tunnel_interface": {
          "const": "kyclash0"
        },
        "site_interface": {
          "$ref": "#/$defs/interface_name"
        },
        "private_cidrs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/cidr"
          }
        },
        "return_path": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode"],
          "properties": {
            "mode": {
              "const": "routed"
            }
          }
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_active_clients",
        "max_active_carriers",
        "carrier_handshake_timeout_seconds",
        "health_interval_seconds",
        "idle_timeout_seconds",
        "shutdown_grace_seconds"
      ],
      "properties": {
        "max_active_clients": {
          "const": 1,
          "description": "Version 1 is intentionally single-active-client even when more than one client identity is pre-authorized."
        },
        "max_active_carriers": {
          "const": 1
        },
        "carrier_handshake_timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 30
        },
        "health_interval_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 60
        },
        "idle_timeout_seconds": {
          "type": "integer",
          "minimum": 30,
          "maximum": 900
        },
        "shutdown_grace_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 30
        }
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "wireguard_public_key": {
      "type": "string",
      "pattern": "^[A-Za-z0-9+/]{43}=$"
    },
    "client": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "public_key_base64", "tunnel_addresses"],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "public_key_base64": {
          "$ref": "#/$defs/wireguard_public_key"
        },
        "tunnel_addresses": {
          "$ref": "#/$defs/host_prefixes"
        }
      }
    },
    "host_prefixes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/cidr"
      }
    },
    "cidr": {
      "type": "string",
      "minLength": 3,
      "maxLength": 64,
      "pattern": "^[0-9A-Fa-f:.]+/[0-9]{1,3}$"
    },
    "interface_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 15,
      "pattern": "^[A-Za-z0-9_.-]+$"
    },
    "bind_address": {
      "type": "string",
      "minLength": 3,
      "maxLength": 96
    },
    "listener_base": {
      "type": "object",
      "additionalProperties": false,
      "required": ["transport", "bind", "url"],
      "properties": {
        "transport": {
          "enum": ["quic", "wss", "tcp"]
        },
        "bind": {
          "$ref": "#/$defs/bind_address"
        },
        "url": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048
        }
      }
    },
    "quic_listener": {
      "allOf": [
        {
          "$ref": "#/$defs/listener_base"
        },
        {
          "properties": {
            "transport": {
              "const": "quic"
            },
            "url": {
              "type": "string",
              "pattern": "^https://"
            }
          }
        }
      ]
    },
    "wss_listener": {
      "allOf": [
        {
          "$ref": "#/$defs/listener_base"
        },
        {
          "properties": {
            "transport": {
              "const": "wss"
            },
            "url": {
              "type": "string",
              "pattern": "^wss://[^?#]+/kynp$"
            }
          }
        }
      ]
    },
    "tcp_listener": {
      "allOf": [
        {
          "$ref": "#/$defs/listener_base"
        },
        {
          "properties": {
            "transport": {
              "const": "tcp"
            },
            "url": {
              "type": "string",
              "pattern": "^tcp://"
            }
          }
        }
      ]
    }
  }
}
