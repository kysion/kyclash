{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.kysion.net/kyclash/network/production/v2.json",
  "title": "KyClash Production Network Profile v2",
  "description": "Secret-free signed production profile paired with exactly one KyClash Linux Peer v2 configuration. The Go decoder additionally enforces duplicate-key, nesting, canonical Base64, canonical prefix, prefix-containment, overlap, endpoint-coherence, and exact family invariants.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "carrier_auth_version",
    "profile_id",
    "control_plane",
    "identity_ref",
    "site",
    "tunnel",
    "transports",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "const": 2
    },
    "carrier_auth_version": {
      "const": 1
    },
    "profile_id": {
      "$ref": "#/$defs/identifier"
    },
    "control_plane": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2048,
      "pattern": "^https://(?:[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?\\.)+(?=[a-z0-9-]*[a-z][a-z0-9-]*(?::|/|$))[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?(?::(?:[1-9]|[1-9][0-9]{1,3}|[1-5][0-9]{4}|6[0-4][0-9]{3}|65[0-4][0-9]{2}|655[0-2][0-9]|6553[0-5]))?(?:/[A-Za-z0-9._~!$&'()*+,;=:@/-]*)?$"
    },
    "identity_ref": {
      "type": "string",
      "minLength": 10,
      "maxLength": 137,
      "pattern": "^keychain:[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "site": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "display_name", "private_cidrs"],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "display_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^(?![\\s\\S]*[\\uD800-\\uDFFF])[^\\u0009-\\u000D\\u0020\\u0085\\u00A0\\u1680\\u2000-\\u200A\\u2028\\u2029\\u202F\\u205F\\u3000]([\\s\\S]*[^\\u0009-\\u000D\\u0020\\u0085\\u00A0\\u1680\\u2000-\\u200A\\u2028\\u2029\\u202F\\u205F\\u3000])?$"
        },
        "private_cidrs": {
          "$ref": "#/$defs/private_prefixes"
        }
      }
    },
    "tunnel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_addresses",
        "local_public_key",
        "peer_public_key",
        "keepalive_seconds"
      ],
      "properties": {
        "local_addresses": {
          "$ref": "#/$defs/host_prefixes"
        },
        "local_public_key": {
          "$ref": "#/$defs/wireguard_public_key"
        },
        "peer_public_key": {
          "$ref": "#/$defs/wireguard_public_key"
        },
        "keepalive_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    },
    "transports": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary", "fallbacks", "endpoints"],
      "properties": {
        "primary": {
          "const": "quic"
        },
        "fallbacks": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "prefixItems": [
            {
              "const": "wss"
            },
            {
              "const": "tcp"
            }
          ],
          "items": false
        },
        "endpoints": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "prefixItems": [
            {
              "$ref": "#/$defs/quic_endpoint"
            },
            {
              "$ref": "#/$defs/wss_endpoint"
            },
            {
              "$ref": "#/$defs/tcp_endpoint"
            }
          ],
          "items": false,
          "description": "The Go decoder additionally requires one canonical lowercase DNS host and three distinct explicit unprivileged ports."
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "connect_timeout_seconds",
        "health_interval_seconds",
        "fallback_threshold"
      ],
      "properties": {
        "connect_timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 300
        },
        "health_interval_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 300
        },
        "fallback_threshold": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20
        }
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "wireguard_public_key": {
      "type": "string",
      "pattern": "^[A-Za-z0-9+/]{41}[A-HQ-Xg-nw-z0-3][AEIMQUYcgkosw048]=$",
      "not": {
        "enum": [
          "7f///////////////////////////////////////38=",
          "7v///////////////////////////////////////38=",
          "7////////////////////////////////////////38=",
          "8P///////////////////////////////////////38=",
          "8f///////////////////////////////////////38=",
          "8v///////////////////////////////////////38=",
          "8////////////////////////////////////////38=",
          "9P///////////////////////////////////////38=",
          "9f///////////////////////////////////////38=",
          "9v///////////////////////////////////////38=",
          "9////////////////////////////////////////38=",
          "+P///////////////////////////////////////38=",
          "+f///////////////////////////////////////38=",
          "+v///////////////////////////////////////38=",
          "+////////////////////////////////////////38=",
          "/P///////////////////////////////////////38=",
          "/f///////////////////////////////////////38=",
          "/v///////////////////////////////////////38=",
          "/////////////////////////////////////////38="
        ]
      }
    },
    "host_prefixes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/cidr"
      },
      "description": "Canonical private /32 or /128 host prefixes, at most one per address family; enforced by the Go decoder."
    },
    "private_prefixes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/cidr"
      },
      "description": "Canonical, nonoverlapping prefixes wholly contained by the locked private allowlist and bounded to 1 KiB of prefix text; enforced by the Go decoder."
    },
    "cidr": {
      "type": "string",
      "minLength": 3,
      "maxLength": 64,
      "pattern": "^[0-9A-Fa-f:.]+/[0-9]{1,3}$"
    },
    "endpoint_base": {
      "type": "object",
      "additionalProperties": false,
      "required": ["transport", "url"],
      "properties": {
        "transport": {
          "enum": ["quic", "wss", "tcp"]
        },
        "url": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048
        }
      }
    },
    "quic_endpoint": {
      "allOf": [
        {
          "$ref": "#/$defs/endpoint_base"
        },
        {
          "properties": {
            "transport": {
              "const": "quic"
            },
            "url": {
              "type": "string",
              "pattern": "^https://(?![0-9.]+:)(?:[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?\\.)+[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?:(?:10(?:2[4-9]|[3-9][0-9])|1[1-9][0-9]{2}|[2-9][0-9]{3}|[1-5][0-9]{4}|6[0-4][0-9]{3}|65(?:[0-4][0-9]{2}|5(?:[0-2][0-9]|3[0-5])))$"
            }
          }
        }
      ]
    },
    "wss_endpoint": {
      "allOf": [
        {
          "$ref": "#/$defs/endpoint_base"
        },
        {
          "properties": {
            "transport": {
              "const": "wss"
            },
            "url": {
              "type": "string",
              "pattern": "^wss://(?![0-9.]+:)(?:[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?\\.)+[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?:(?:10(?:2[4-9]|[3-9][0-9])|1[1-9][0-9]{2}|[2-9][0-9]{3}|[1-5][0-9]{4}|6[0-4][0-9]{3}|65(?:[0-4][0-9]{2}|5(?:[0-2][0-9]|3[0-5])))/kynp$"
            }
          }
        }
      ]
    },
    "tcp_endpoint": {
      "allOf": [
        {
          "$ref": "#/$defs/endpoint_base"
        },
        {
          "properties": {
            "transport": {
              "const": "tcp"
            },
            "url": {
              "type": "string",
              "pattern": "^tcp://(?![0-9.]+:)(?:[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?\\.)+[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?:(?:10(?:2[4-9]|[3-9][0-9])|1[1-9][0-9]{2}|[2-9][0-9]{3}|[1-5][0-9]{4}|6[0-4][0-9]{3}|65(?:[0-4][0-9]{2}|5(?:[0-2][0-9]|3[0-5])))$"
            }
          }
        }
      ]
    }
  }
}
